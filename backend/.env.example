# ════════════════════════════════════════════════════════════════════════════
#  backend/.env  —  Local Whisper Transcription Configuration
#  Copy this file:  cp .env.example .env
# ════════════════════════════════════════════════════════════════════════════

# ── Whisper Model ─────────────────────────────────────────────────────────────
# Size options: tiny | base | small | medium | large  (default: base)
# Model downloads automatically on first run to ~/.cache/huggingface/
WHISPER_MODEL=base


# ── Local File Storage ────────────────────────────────────────────────────────
# Leave blank → auto-detects system temp dir (Windows & Linux compatible)
TEMP_DIR=
MAX_FILE_SIZE_MB=500


# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file stored in the backend directory
DATABASE_URL=sqlite+aiosqlite:///./transcription.db


# ── CORS (allowed frontend origins) ──────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]


# ── FFmpeg ────────────────────────────────────────────────────────────────────
# Leave as "ffmpeg" if ffmpeg is on your system PATH.
# Windows example: FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

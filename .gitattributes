# Normalize line endings to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf

# Binary files — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.wav  binary
*.mp3  binary
*.mp4  binary
*.webm binary
*.db   binary
*.db-shm binary
*.db-wal binary
*.lock binary

{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "build": {
    "env": {
      "VITE_API_BASE_URL": "https://multi-lingual-transcription.onrender.com",
      "VITE_WS_BASE_URL": "wss://multi-lingual-transcription.onrender.com"
    }
  }
}
